# OpenAI API key (required for LLM answers; retrieval-only mode works without it)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Play Store
PLAY_STORE_APP_ID=com.spotify.music
PLAY_STORE_APP_NAME=Spotify
PLAY_STORE_REVIEW_COUNT=100

# App Store
APP_STORE_APP_ID=324684580
APP_STORE_APP_NAME=Spotify
APP_STORE_REVIEW_COUNT=100

# Reddit (public JSON API — no credentials required)
REDDIT_SUBREDDITS=["spotify","AppleMusic","music"]
REDDIT_SEARCH_QUERY=discovery OR recommendation OR playlist
REDDIT_POST_LIMIT=50
